rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin check helper
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'aurixbank@gmail.com';
    }

    // Pending registrations
    match /pendingRegistrations/{regId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Admin login tokens
    match /adminLoginTokens/{email} {
      allow read, write: if false; // Only Cloud Functions
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Accounts
    match /accounts/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Transactions
    match /transactions/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId && 
                    !get(/databases/$(database)/documents/users/$(userId)).data.isFlagged;
      allow update: if isAdmin();
    }

    // Cards
    match /cards/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId && 
                    !get(/databases/$(database)/documents/users/$(userId)).data.isFlagged;
    }
  }
}
